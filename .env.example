# Local development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/varmova_partner_portal?schema=public"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Vercel production / preview
# On Vercel, NEXTAUTH_URL is usually not required explicitly for NextAuth.
# Add this only when needed outside Vercel or for custom setups.
# NEXTAUTH_URL="https://your-domain.vercel.app"

# Optional: persistent file uploads on Vercel via Vercel Blob
BLOB_READ_WRITE_TOKEN=""
